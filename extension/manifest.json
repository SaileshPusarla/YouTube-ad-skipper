{
  "manifest_version": 3,
  "name": "YouTube Ad Skipper",
  "version": "1.0.0",
  "description": "Automatically skips, mutes, and removes YouTube ads.",
  "permissions": [],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
